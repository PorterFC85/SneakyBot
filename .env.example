DISCORD_TOKEN=your_bot_token
DISCORD_CLIENT_ID=your_application_client_id
DISCORD_GUILD_ID=your_test_or_main_server_id
# Enable Message Content Intent in the Discord Developer Portal if you want !command retrieval.
# Optional multi-server format (comma-separated IDs). If set, this is used instead of DISCORD_GUILD_ID.
# DISCORD_GUILD_IDS=2222222222222222,111111111111111111
# Optional access control (comma-separated IDs). If both are blank, everyone in allowed servers can use commands.
# ALLOWED_USER_IDS=111111111111111111,222222222222222222
# ALLOWED_ROLE_IDS=333333333333333333,444444444444444444
# Optional service controls (comma-separated user IDs).
# BOT_ADMIN_USER_IDS=111111111111111111,222222222222222222
# BOT_BANNED_USER_IDS=333333333333333333
# Optional: restrict /cut and /cuts to one or more channel IDs (comma-separated).
# CUT_POLL_CHANNEL_ID=1483875995399360736,1263216486088966215
# Optional for this project (not required unless you implement HTTP interaction verification)
DISCORD_PUBLIC_KEY=your_application_public_key
